/* pages/group/group.wxss */
.pb-120 { padding-bottom: 140rpx; }
.header .title { display: block; font-size: 40rpx; font-weight: bold; }
.header .subtitle { font-size: 26rpx; color: var(--text-secondary); }

/* 卡片 */
.group-card {
  margin-bottom: 30rpx;
  background-image: linear-gradient(135deg, rgba(255,87,34,0.05) 0%, var(--card-bg) 100%);
  border: 1px solid var(--border-color);
}
.group-name { font-size: 34rpx; font-weight: bold; color: var(--text-main); }
.member-count { font-size: 24rpx; color: var(--primary-color); background: rgba(255,87,34,0.1); padding: 4rpx 16rpx; border-radius: 20rpx; }
.group-desc { font-size: 26rpx; color: var(--text-secondary); margin-bottom: 10rpx; }
.group-footer { border-top: 1px dashed var(--border-color); padding-top: 20rpx; }
.group-id { font-size: 24rpx; font-family: monospace; font-weight: bold; letter-spacing: 2rpx; color: var(--text-main); }
.text-hint { font-size: 24rpx; color: var(--text-secondary); }

/* 底部按钮 */
.bottom-action {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  background: var(--card-bg); z-index: 10; gap: 30rpx;
}
.btn-half { flex: 1; border-radius: 50rpx; font-size: 32rpx; }
.btn-join { background-color: var(--background-color) !important; color: var(--text-main); }
.btn-create { background-color: var(--primary-color) !important; color: #fff; }

/* 弹窗及复用 */
.empty-state { margin-top: 100rpx; opacity: 0.6; }
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; }
.modal-content { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 80%; z-index: 101; }
.modal-header { text-align: center; margin-bottom: 30rpx; font-weight: bold; font-size: 34rpx; }
.form-group { margin-bottom: 24rpx; }
.form-group .label { font-size: 28rpx; color: var(--text-secondary); margin-bottom: 12rpx; }
.form-input { background-color: var(--background-color); padding: 16rpx 20rpx; border-radius: 12rpx; font-size: 28rpx; }
.modal-footer { margin-top: 40rpx; gap: 20rpx; }
.btn-modal { flex: 1; border-radius: 50rpx; font-size: 30rpx; }
.btn-cancel { background-color: var(--background-color); }
.btn-confirm { background-color: var(--primary-color) !important; color: #fff; }