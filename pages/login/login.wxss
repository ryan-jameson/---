/* pages/login/login.wxss */
.login-page {
  height: 100vh;
  background-color: var(--background-color);
  justify-content: space-around;
  padding: 60rpx 40rpx;
}

.logo-box {
  margin-top: 100rpx;
}

.app-logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 87, 34, 0.2);
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--text-main);
  margin-bottom: 16rpx;
}

.app-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.btn-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.login-btn {
  background-color: var(--primary-color) !important;
  color: #fff;
  border-radius: 50rpx;
  font-size: 34rpx;
  width: 80% !important;
  box-shadow: 0 10rpx 30rpx rgba(255, 87, 34, 0.3);
  margin-bottom: 30rpx;
}

.tips {
  font-size: 24rpx;
  color: #aaaaaa;
}