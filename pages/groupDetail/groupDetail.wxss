/* pages/groupDetail/groupDetail.wxss */
.hero-card {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
  color: #fff;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(255, 87, 34, 0.3);
}
.g-name { font-size: 40rpx; font-weight: bold; }
.btn-quit { margin: 0; background: rgba(0,0,0,0.15); color: #fff; font-size: 24rpx; border-radius: 30rpx; padding: 0 20rpx; line-height: 50rpx; }
.g-desc { font-size: 28rpx; opacity: 0.9; margin-bottom: 20rpx;}
.g-code-box { background: rgba(0,0,0,0.1); padding: 16rpx 20rpx; border-radius: 12rpx; }
.g-code-label { font-size: 26rpx; }
.g-code { font-size: 32rpx; font-family: monospace; font-weight: bold; letter-spacing: 4rpx; }
.copy-hint { font-size: 24rpx; opacity: 0.8; }

/* 排序切换控制 */
.rank-tabs { background: var(--border-color); padding: 6rpx; border-radius: 40rpx; }
.tag { font-size: 24rpx; padding: 10rpx 24rpx; border-radius: 30rpx; color: var(--text-secondary); transition: all 0.3s;}
.tag.active { background: #fff; color: var(--primary-color); font-weight: bold; box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.05);}

.title { font-size: 32rpx; font-weight: bold; }
.subtitle { font-size: 26rpx; color: var(--text-secondary); }

/* 成员列表 */
.member-item {
  margin-bottom: 20rpx; padding: 20rpx;
}
.rank-num {
  width: 40rpx; font-size: 32rpx; font-weight: bold; font-style: italic; color: var(--text-secondary); text-align: center; margin-right: 16rpx;
}
.top-1 { color: #FFD700; font-size: 36rpx; }
.top-2 { color: #C0C0C0; font-size: 34rpx; }
.top-3 { color: #CD7F32; font-size: 32rpx; }

.avatar { width: 80rpx; height: 80rpx; border-radius: 50%; background: var(--background-color); margin-right: 20rpx;}
.m-info { flex: 1; }
.m-name { font-size: 30rpx; font-weight: 500; }
.role-tag { font-size: 20rpx; background: rgba(255,87,34,0.1); color: var(--primary-color); padding: 2rpx 10rpx; border-radius: 8rpx; margin-left: 10rpx; }
.m-stats { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; }

.focus-time { min-width: 100rpx; }
.time-val { font-size: 40rpx; font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif; color: var(--text-secondary); }
.time-val.active { color: var(--primary-color); }
.time-unit { font-size: 20rpx; color: var(--text-secondary); }

/* 下方互助条和按钮 */
.interact-bar { border-top: 1px dashed var(--border-color); padding-top: 16rpx; }
.stat-pill { font-size: 22rpx; color: #888; background: var(--background-color); padding: 4rpx 16rpx; border-radius: 20rpx; }
.action-item { padding: 4rpx 16rpx; border-radius: 30rpx; background: rgba(255,87,34,0.05); }
.action-item:active { opacity: 0.7; }
.icon { font-size: 28rpx; margin-right: 6rpx; }
.a-text { font-size: 24rpx; color: var(--primary-color); font-weight: bold; }
.ml-20 { margin-left: 20rpx; }

/* 鼓励墙留言样式 */
.wall-title { font-size: 32rpx; font-weight: bold; margin-left:10rpx; }
.msg-box { padding: 20rpx; max-height: 400rpx; overflow-y: auto;}
.msg-item { font-size: 26rpx; margin-bottom: 16rpx; display: flex; flex-wrap: wrap; line-height: 1.5;}
.msg-item:last-child { margin-bottom: 0; }
.msg-from { font-weight: bold; color: #03A9F4; margin-right: 10rpx; }
.msg-action { color: var(--text-secondary); margin-right: 10rpx;}
.msg-text { color: var(--text-main); flex: 1; }

/* 弹窗样式补充 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; }
.modal-content { position: fixed; top: 40%; left: 50%; transform: translate(-50%, -50%); width: 80%; z-index: 101; background: var(--card-bg); padding:30rpx; border-radius: 20rpx;}
.modal-header { font-weight: bold; font-size: 32rpx; margin-bottom: 20rpx; text-align: center;}
.form-input { background: var(--background-color); padding: 20rpx; border-radius: 12rpx; width: 100%; box-sizing: border-box; font-size: 28rpx;}
.modal-footer { gap: 20rpx; display:flex;}
.btn-modal { flex: 1; border-radius: 50rpx; font-size: 30rpx; }
.btn-cancel { background-color: var(--background-color); }
.btn-confirm { background-color: var(--primary-color) !important; color: #fff; margin:0 !important;}