/* pages/record/record.wxss */
.pb-40 { padding-bottom: 60rpx; }

/* 顶部分类 Tabs */
.top-tabs {
  background-color: var(--card-bg);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  padding: 10rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: var(--text-secondary);
  position: relative;
  transition: all 0.3s;
}
.tab-item.active {
  color: var(--primary-color);
  font-weight: bold;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0; left: 35%; right: 35%;
  height: 6rpx;
  background-color: var(--primary-color);
  border-radius: 10rpx;
}

/* 日期选择区 */
.date-picker-box { padding: 30rpx; }
.date-label { font-size: 30rpx; font-weight: bold; }
.date-value { background-color: var(--background-color); padding: 12rpx 24rpx; border-radius: 40rpx; color: var(--primary-color); font-weight: bold; }
.arrow { font-size: 20rpx; margin-left: 10rpx; }

/* 日常主板 */
.daily-dash { padding: 40rpx 20rpx; }
.dash-item { flex: 1; }
.dash-divider { width: 2rpx; background-color: var(--border-color); margin: 0 20rpx; }
.dash-num { font-size: 56rpx; font-weight: bold; font-family: Impact, sans-serif; }
.dash-num.primary { color: var(--primary-color); }
.dash-desc { font-size: 26rpx; color: var(--text-secondary); margin-top: 10rpx;}

/* 总结输入区 */
.section-title { font-size: 30rpx; font-weight: bold; margin-bottom: 20rpx; }
.summary-input { width: 100%; height: 200rpx; background-color: var(--background-color); padding: 20rpx; border-radius: 16rpx; font-size: 28rpx; box-sizing: border-box;}
.word-count { font-size: 24rpx; color: var(--text-secondary); }
.btn-save { margin: 0 !important; font-size: 28rpx !important; border-radius: 40rpx; padding: 0 40rpx !important; line-height: 60rpx !important;}

/* 番茄足迹（列表） */
.history-item { padding: 20rpx 0; border-bottom: 1px dashed var(--border-color); }
.history-item:last-child { border-bottom: none; }
.dot { width: 16rpx; height: 16rpx; background-color: var(--primary-color); border-radius: 50%; margin-right: 16rpx; }
.h-time { font-size: 28rpx; color: var(--text-secondary); margin-right: 20rpx; font-family: monospace;}
.h-content { font-size: 28rpx; color: var(--text-main); flex: 1;}
.h-focus { font-size: 28rpx; font-weight: bold; color: #4CAF50; }

/* ====== 统计图表区 ======== */
.segment-control { background: #e0e0e0; border-radius: 12rpx; padding: 6rpx; display: inline-flex; width: 100%; }
.seg-item { flex: 1; text-align: center; padding: 14rpx 0; font-size: 28rpx; border-radius: 8rpx; color: #666; transition: all 0.2s;}
.seg-item.active { background: #fff; color: var(--text-main); font-weight: bold; box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.05); }
@media (prefers-color-scheme: dark) {
  .segment-control { background: #333; }
  .seg-item.active { background: var(--card-bg); color: #fff;}
}

.board-card { padding: 50rpx 0; }
.circle-chart { width: 280rpx; height: 280rpx; border: 16rpx solid var(--primary-color); border-radius: 50%; display: flex; flex-direction: column; justify-content: center; align-items: center; margin-bottom: 30rpx; box-shadow: inset 0 0 30rpx rgba(255,87,34,0.1); }
.circle-val { font-size: 70rpx; font-weight: bold; color: var(--text-main); font-family: monospace; }
.circle-unit { font-size: 24rpx; color: var(--text-secondary); }
.board-title { font-size: 32rpx; font-weight: bold; color: var(--text-secondary); }

.half-card { width: 48%; padding: 40rpx 0; }
.h-icon { width: 60rpx; height: 60rpx; margin-bottom: 20rpx; opacity: 0.8;}
.h-num { font-size: 44rpx; font-weight: bold; color: var(--text-main); margin-bottom: 8rpx; }
.h-title { font-size: 26rpx; color: var(--text-secondary); }
.text-center { text-align: center; }